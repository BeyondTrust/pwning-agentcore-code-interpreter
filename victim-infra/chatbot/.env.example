# Victim Chatbot Environment Variables
# Copy this file to .env and fill in values

# AWS Configuration
AWS_REGION=us-east-1

# Code Interpreter Configuration (from Terraform output)
# Leave empty for local development (uses mock analysis)
CODE_INTERPRETER_ID=
CODE_INTERPRETER_ARN=

# Application Configuration
APP_TITLE=AI Data Analyst
APP_VERSION=1.0.0
LOG_LEVEL=INFO
