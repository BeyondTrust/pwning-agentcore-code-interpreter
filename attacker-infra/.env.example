# Attacker Infrastructure Environment Variables
# Copy this file to .env and fill in values after running `make deploy`

# AWS EC2 Instance (C2 Server)
# Public IP of the DNS C2 server
EC2_IP=

# EC2 instance ID for SSM access
EC2_INSTANCE_ID=

# DNS domain for C2 communication
DOMAIN=c2.bt-research-control.com

# S3 bucket for storing deployment artifacts
S3_BUCKET=

# Optional: Override C2 server URL (defaults to http://$EC2_IP:8080)
# C2_SERVER_URL=
